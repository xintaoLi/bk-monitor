    "vue-loader": "^17.4.0",
    "vue-tsc": "^2.0.0",
    "webpack": "^5.91.0",
    "webpack-bundle-analyzer": "^4.10.2",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.4",
    "webpackbar": "6.0.1"
  },
  "engines": {
    "node": ">= 18"
  }
