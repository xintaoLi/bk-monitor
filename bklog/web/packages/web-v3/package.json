{
  "name": "@bklog/web-v3",
  "version": "1.0.0",
  "description": "蓝鲸日志平台 Vue3 升级版本",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development webpack serve --config webpack.config.cjs",
    "dev:apm": "cross-env NODE_ENV=development MONITOR_APP=apm webpack serve --config webpack.config.cjs",
    "dev:trace": "cross-env NODE_ENV=development MONITOR_APP=trace webpack serve --config webpack.config.cjs",
    "build": "cross-env NODE_ENV=production webpack --config webpack.config.cjs",
    "build:apm": "cross-env NODE_ENV=production MONITOR_APP=apm webpack --config webpack.config.cjs",
    "build:trace": "cross-env NODE_ENV=production MONITOR_APP=trace webpack --config webpack.config.cjs",
    "analyze": "cross-env NODE_ENV=production ANALYZE=true webpack --config webpack.config.cjs",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "stylelint": "stylelint \"src/**/*.{vue,scss,css}\" --fix"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.18.6",
    "@codemirror/commands": "^6.8.1",
    "@codemirror/lang-javascript": "6.2.2",
    "@codemirror/lang-json": "6.0.1",
    "@codemirror/lang-sql": "6.7.1",
    "@codemirror/language": "6.10.2",
    "@codemirror/search": "^6.5.11",
    "@codemirror/state": "6.4.1",
    "@codemirror/view": "6.33.0",
    "@vueuse/core": "^10.9.0",
    "axios": "1.8.2",
    "codemirror": "6.0.1",
    "dayjs": "1.11.10",
    "deepmerge": "4.3.1",
    "dompurify": "^3.2.6",
    "echarts": "5.2.2",
    "js-cookie": "3.0.5",
    "json-bigint": "^1.0.0",
    "lodash-es": "4.17.21",
    "mark.js": "8.11.1",
    "markdown-it": "14.1.0",
    "monaco-editor": "0.33.0",
    "monaco-yaml": "^5.4.1",
    "pinia": "^2.1.7",
    "qs": "6.11.2",
    "screenfull": "6.0.2",
    "sql-formatter": "15.6.6",
    "tdesign-vue-next": "^1.9.0",
    "throttle-debounce": "5.0.0",
    "tiny-pinyin": "1.3.2",
    "tippy.js": "6.3.7",
    "vue": "^3.4.0",
    "vue-i18n": "^9.10.0",
    "vue-router": "^4.3.0",
    "vue-virtual-scroller": "^2.0.0-beta.8"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-typescript": "^7.24.0",
    "@types/dompurify": "^3.0.5",
    "@types/js-cookie": "^3.0.6",
    "@types/lodash-es": "^4.17.12",
    "@types/mark.js": "^8.11.12",
    "@types/node": "^20.12.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitejs/plugin-vue-jsx": "^3.1.0",
    "@vue/babel-plugin-jsx": "^1.2.2",
    "@vue/tsconfig": "^0.5.1",
    "babel-loader": "9.2.1",
    "copy-webpack-plugin": "^12.0.2",
    "cross-env": "7.0.3",
    "css-loader": "7.1.2",
    "css-minimizer-webpack-plugin": "^7.0.0",
    "html-webpack-plugin": "^5.6.0",
    "mini-css-extract-plugin": "^2.9.0",
    "monaco-editor-webpack-plugin": "7.0.1",
    "postcss-loader": "8.1.1",
